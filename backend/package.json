{
  "name": "whatsapp-saas-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "npx prisma migrate deploy && npx prisma generate && node dist/index.js",
    "postinstall": "npm run build && npx prisma generate",
    "db:health": "curl -s http://localhost:3001/api/health | jq .",
    "db:backup": "pg_dump $DATABASE_URL > backup_$(date +%Y%m%d_%H%M%S).sql",
    "prisma:reset": "npx prisma migrate reset --force",
    "prisma:deploy": "npx prisma migrate deploy && npx prisma generate"
  },
  "dependencies": {
    "express": "^4.18.3",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "axios": "^1.6.7",
    "dotenv": "^16.4.5",
    "zod": "^3.22.4",
    "prisma": "^7.4.2",
    "@prisma/client": "^7.4.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3",
    "tsx": "^4.7.1"
  }
}
