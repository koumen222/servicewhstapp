ng\" sizes=\"32x32\" type=\"image/png\"/><link rel=\"apple-touch-icon\" href=\"/logo.png\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"antialiased bg-[#0f0f0f] text-[#f0f0f0]\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"min-h-screen flex bg-[#0a0a0a] bg-grid-green\"><div class=\"hidden lg:flex flex-col justify-between w-[420px] shrink-0 p-10 border-r border-[#141414]\"><div class=\"flex items-center gap-2.5\"><img src=\"/logo.png\" alt=\"ZeChat.site\" class=\"w-8 h-8 object-contain\"/><span class=\"text-[17px] font-bold text-white tracking-tight\">ZeChat<span class=\"text-green-500\">.site</span></span></div><div><div class=\"w-12 h-12 rounded-2xl flex items-center justify-center mb-6\" style=\"background:#0d2510\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-message-square text-[#22c55e]\"><path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\"></path></svg></div><blockquote class=\"text-[22px] font-semibold text-white leading-snug mb-4\">&quot;La plateforme d&#x27;automatisation WhatsApp la plus puissante pour les entreprises en Afrique.&quot;</blockquote><p class=\"text-[13px] text-[#5a7a5a]\">Gérez plusieurs instances WhatsApp, automatisez vos messages et développez votre relation client.</p></div><div class=\"flex items-center gap-3\"><div class=\"flex -space-x-2\"><div class=\"w-8 h-8 rounded-full border-2 border-[#0a0a0a] flex items-center justify-center text-[10px] font-bold text-black\" style=\"background:#22c55e\">A</div><div class=\"w-8 h-8 rounded-full border-2 border-[#0a0a0a] flex items-center justify-center text-[10px] font-bold text-black\" style=\"background:#3b82f6\">B</div><div class=\"w-8 h-8 rounded-full border-2 border-[#0a0a0a] flex items-center justify-center text-[10px] font-bold text-black\" style=\"background:#8b5cf6\">C</div><div class=\"w-8 h-8 rounded-full border-2 border-[#0a0a0a] flex items-center justify-center text-[10px] font-bold text-black\" style=\"background:#f59e0b\">D</div></div><p class=\"text-[12px] text-[#5a7a5a]\">Rejoignez plus de <span class=\"text-[#22c55e] font-medium\">500</span> entreprises locales</p></div></div><div class=\"flex-1 flex items-center justify-center p-6\"><div class=\"w-full max-w-[400px]\" style=\"opacity:0;transform:translateY(16px)\"><div class=\"flex items-center gap-2 mb-8 lg:hidden\"><img src=\"/logo.png\" alt=\"ZeChat.site\" class=\"w-8 h-8 object-contain\"/><span class=\"text-[17px] font-bold text-white tracking-tight\">ZeChat<span class=\"text-green-500\">.site</span></span></div><h1 class=\"text-2xl font-bold text-white mb-1\">Bon retour parmi nous</h1><p class=\"text-[13px] text-[#5a7a5a] mb-7\">Connectez-vous à votre compte pour continuer</p><form class=\"space-y-4\"><div><label class=\"block text-xs font-medium text-[#8a9a8a] mb-1.5\">Adresse email</label><input type=\"email\" placeholder=\"moussa.traore@exemple.com\" autoComplete=\"email\" autofocus=\"\" class=\"input-dark w-full\" name=\"email\"/></div><div><div class=\"flex items-center justify-between mb-1.5\"><label class=\"text-xs font-medium text-[#8a9a8a]\">Mot de passe</label><button type=\"button\" class=\"text-[11px] text-[#22c55e] hover:text-[#4ade80] transition-colors\">Mot de passe oublié ?</button></div><div class=\"relative\"><input type=\"password\" placeholder=\"••••••••\" autoComplete=\"current-password\" class=\"input-dark w-full pr-10\" name=\"password\"/><button type=\"button\" class=\"absolute right-3 top-1/2 -translate-y-1/2 text-[#4a6a4a] hover:text-white transition-colors\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-eye\"><path d=\