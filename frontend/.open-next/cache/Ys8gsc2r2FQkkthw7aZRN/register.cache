b0a.js\" noModule=\"\"></script></head><body class=\"antialiased bg-[#0f0f0f] text-[#f0f0f0]\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"min-h-screen flex bg-[#0a0a0a] bg-grid-green\"><div class=\"hidden lg:flex flex-col justify-between w-[420px] shrink-0 p-10 border-r border-[#141414]\"><div class=\"flex items-center gap-2.5\"><img src=\"/logo.png\" alt=\"Logo\" class=\"w-8 h-8 object-contain\"/></div><div><h2 class=\"text-2xl font-bold text-white mb-2\">Commencez gratuitement dès aujourd&#x27;hui</h2><p class=\"text-[13px] text-[#5a7a5a] mb-6\">Tout ce dont vous avez besoin pour construire une automatisation WhatsApp puissante.</p><ul class=\"space-y-3\"><li class=\"flex items-center gap-2.5\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check text-[#22c55e] shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-[13px] text-[#8a9a8a]\">Jusqu&#x27;à 1 instance WhatsApp gratuite</span></li><li class=\"flex items-center gap-2.5\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check text-[#22c55e] shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-[13px] text-[#8a9a8a]\">Accès API avec webhooks</span></li><li class=\"flex items-center gap-2.5\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check text-[#22c55e] shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-[13px] text-[#8a9a8a]\">Suivi des messages en temps réel</span></li><li class=\"flex items-center gap-2.5\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check text-[#22c55e] shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-[13px] text-[#8a9a8a]\">Évoluez à tout moment vers plus d&#x27;instances</span></li></ul></div><div class=\"p-4 rounded-xl\" style=\"background:#0d2510;border:1px solid #1a3a1a\"><p class=\"text-[12px] text-[#22c55e] font-semibold mb-1\">Le plan gratuit inclut</p><p class=\"text-[12px] text-[#5a7a5a]\">1 instance · 1 000 messages/mois · Accès complet à l&#x27;API</p></div></div><div class=\"flex-1 flex flex-col p-6\"><div class=\"w-full max-w-2xl mx-auto flex flex-col h-full\" style=\"opacity:0;transform:translateY(16px)\"><div class=\"flex items-center justify-between mb-6\"><img src=\"/logo.png\" alt=\"Logo\" class=\"w-8 h-8 object-contain\"/><a class=\"inline-flex items-center gap-2 bg-green-600 hover:bg-green-500 text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors\" href=\"/login\">Se connecter</a></div><div class=\"mb-6\"><div class=\"flex items-center gap-2 mb-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sparkles h-5 w-5 text-green-500\"><path d=\"M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z\"></path><path d=\"M20 3v4\"></path><path d=\"M22 5h-4\"></path><path d=\"M4 17v2\"></path><path d=\"M5 18H3\"></path></svg><h1 class=\"text-2xl font-bold text-white\">Créer votre compte</h1></div><p class=\"text-[13px] text-[#5a7a5a]\">Répondez aux questions de notre assistant pour créer votre compte en quelques secondes</p></div><div class=\"flex-1 overflow-y-auto mb-4 space-y-4 pr-2 no-scrollbar\"><div class=\"flex justify-start\" style=\"opacity:0;transform:translateY(10px)\"><div class=\"max-w-[80%] rounded-2xl px-4 py-3 bg-zinc-900 border border-zinc-800 text-zinc-200 rounded-tl-sm\"><p class=\"text-sm leading-relaxed whitespace-pre-wrap\">Bonjour ! 👋 Je suis ravi de vous aider à créer votre compte. Pour commencer, comment vous appelez-vous ?</p></div></div><div></div></div><form class=\"flex items-center gap-2\"><input type=\"text\" placeholder=\"Ex: Moussa Traoré\" class=\"flex-1 bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-3 text-sm text-white placeholder:text-zinc-600 focus:outline-none focus:border-green-500/50 focus:ring-2 focus:ring-green-500/20 transition-all disabled:opacity-50 disabled:cursor-not-allowed\" autoComplete=\"off\" value=\"\"/><button type=\"submit\" disabled=\"\" class=\"bg-green-600 hover:bg-green-500 disabled:bg-zinc-800 disabled:cursor-not-allowed text-white rounded-xl p-3 transition-all disabled:opacity-50 flex items-center justify-center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-send h-5 w-5\"><path d=\"M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z\"></path><path d=\"m21.854 2.147-10.94 10.939\"></path></svg></button></form><div class=\"mt-4 text-center\"><p class=\"text-[11px] text-[#3a5a3a]\">En vous inscrivant, vous acceptez nos<!-- --> <span class=\"text-[#22c55e]\">Conditions d&#x27;utilisation</span> et notre<!-- --> <span class=\"text-[#22c5